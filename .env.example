# Database (PostgreSQL)
# For Docker: postgresql://user:password@postgres:5432/db_name
# For Local: postgresql://user:password@localhost:5432/db_name
DATABASE_URL=

# Database Connection (Docker)
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=5432

# JWT Secrets
JWT_SECRET= 
JWT_REFRESH_SECRET= 
JWT_EXPIRATION=86400s
JWT_REFRESH_EXPIRATION=604800s

# API Configuration
API_PORT=3000
API_URL="http://localhost:3000"

# Frontend Configuration
VITE_API_URL=http://localhost:3000
VITE_FRONTEND_URL=http://localhost:5173

# Environment
NODE_ENV=development