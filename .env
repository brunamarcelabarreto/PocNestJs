# Database (PostgreSQL)
# For Docker: postgresql://commandix_user:commandix_password@postgres:5432/commandix_db
# For Local: postgresql://user:password@localhost:5432/commandix_db
DATABASE_URL=

# Database Connection (Docker)
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=

# JWT Secrets
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800

# API Configuration
API_PORT=3000
API_URL=

# Environment
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:5173"

# Environment
NODE_ENV=development

